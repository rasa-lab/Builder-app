{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the X BUILDER application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A saved project containing chat history and generated files.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Owner UID" },
        "name": { "type": "string" },
        "files": { 
          "type": "string", 
          "description": "JSON stringified Record<string, string> of file paths to contents" 
        },
        "messages": { 
          "type": "string", 
          "description": "JSON stringified array of messages" 
        },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["id", "userId", "name", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Saved projects"
    }
  }
}
